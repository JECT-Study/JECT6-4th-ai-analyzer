ENVIRONMENT=local
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/blogai
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

REDIS_URL=redis://localhost:6379/0
CONVERSATION_TTL_SECONDS=3600

RABBITMQ_URL=amqp://guest:guest@localhost:5672/
ANALYSIS_QUEUE_NAME=blog.analysis
WORKER_CONCURRENCY=10

# LLM provider: openai | ollama | demo
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
LLM_MAX_CONCURRENCY=20

# Ollama (LLM_PROVIDER=ollama 시 사용)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b

# Demo mode: true 시 LLM 호출 없이 고정 결과 반환
DEMO_MODE=false

CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=100

CRAWL_STREAM_NAME=crawl:jobs
CRAWL_CONSUMER_GROUP=crawl-workers
CRAWL_DLQ_STREAM_NAME=crawl:jobs:dlq
CRAWL_WORKER_NAME=worker-1
CRAWL_BATCH_SIZE=10
CRAWL_BLOCK_MS=5000
CRAWL_PENDING_IDLE_MS=60000
CRAWL_MAX_RETRIES=3
CRAWL_REQUEST_TIMEOUT_SECONDS=15
CRAWL_USER_AGENT=blog-ai-crawler/1.0
CRAWL_DOMAIN_DELAY_SECONDS=1
CRAWL_MAX_RESPONSE_BYTES=2000000

MAX_CONVERSATION_TOKENS=8000
MAX_TURNS_PER_SESSION=30
